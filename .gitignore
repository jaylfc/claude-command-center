# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Obsidian vault (local notes — not part of the project)
.obsidian/

# Local scratch
/tmp/
/scratch/

# Git worktrees created by superpowers:using-git-worktrees skill
.worktrees/

# Build output (none today, but don't commit if any tooling is added later)
/dist/
/build/

# Local logs or state that might end up in-tree.
# Whole `.claude/` dir is per-machine — settings, session logs, pasted
# images, locks, agent worktree scratch — none of it belongs in git.
/.claude/
*.log

# Coordination file for parallel Claude Code sessions sharing this clone.
# Local-only — see GROUP_CHAT.md itself for the convention.
/GROUP_CHAT.md

# Pre-publish workspace — audit reports, archive prep, etc.
/oss-prep/

# Maintainer's local research notes (competitor scans, licensing reading,
# scratch markdown). Useful for the maintainer, not part of the project.
/competitor-analysis/
/About licensing.md

# Local-only asset workspace (large videos, raw recordings, full-res screenshots)
# Repo only ships compressed/optimized derivatives in docs/images/
/_assets/

# nanobanana MCP generated images — local experiments, not source.
/nanobanana-output/

# Don't accidentally commit large videos anywhere in the tree
*.mp4
*.mov

# ── Local-only "Morning view" plugin ──────────────────────────────────
# Highly opinionated to one user's life (goals, strategies, braindump).
# Kept on disk for the maintainer's daily use; excluded from the OSS
# distribution because most users won't want it. The server detects
# absence at startup and silently disables the routes.
#
# CI runs without these files (it only sees what's in git), so any
# accidental hard-coupling to morning code from non-morning code will
# fail the smoke test on the next push. See .github/workflows/ci.yml.
/morning.py
/morning_store.py
/static/morning/
/scripts/ingest_apple_notes.py
/tests/test_morning.py
/ingesters/
